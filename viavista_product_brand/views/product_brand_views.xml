<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_brand_view_list" model="ir.ui.view">
        <field name="name">product.brand.list</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="image_128" widget="image" options="{'size': [32, 32]}" nolabel="1"/>
                <field name="name"/>
                <field name="product_count" string="# Products"/>
            </list>
        </field>
    </record>

    <record id="product_brand_view_kanban" model="ir.ui.view">
        <field name="name">product.brand.kanban</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside class="o_kanban_aside_full">
                            <field name="image_128" widget="image" class="o_image_64_cover"/>
                        </aside>
                        <main>
                            <field name="name" class="fw-bold fs-5"/>
                            <div>
                                <field name="product_count"/> <span>products</span>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="product_brand_view_form" model="ir.ui.view">
        <field name="name">product.brand.form</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <form string="Brand">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_products" type="object"
                                class="oe_stat_button" icon="fa-cubes">
                            <field name="product_count" widget="statinfo" string="Products"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Brand name..."/></h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_brand_view_search" model="ir.ui.view">
        <field name="name">product.brand.search</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="product_brand_action" model="ir.actions.act_window">
        <field name="name">Brands</field>
        <field name="res_model">product.brand</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_product_brand"
              name="Brands"
              parent="sale.product_menu_catalog"
              action="product_brand_action"
              sequence="15"/>

</odoo>
