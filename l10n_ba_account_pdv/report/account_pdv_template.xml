<odoo>

    <record id="action_report_pdv" model="ir.actions.report">
        <field name="name">Form P VAT</field>
        <field name="model">account.pdv.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_ba_account_pdv.report_pdv</field>
        <field name="report_file">l10n_ba_account_pdv.report_pdv</field>
    </record>

    <template id="report_pdv">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page" style="font-family: Arial, sans-serif; font-size: 11px;">
                    <!-- Header -->
                    <div style="text-align: right; font-size: 10px;">Obrazac P PDV</div>
                    <h3 style="text-align: center; letter-spacing: 8px;">P D V  P R I J A V A</h3>

                    <table style="width: 100%; margin-bottom: 15px;">
                        <tr>
                            <td style="width: 60%;">
                                <div><strong>Naziv poreznog obveznika <small>3</small></strong></div>
                                <div style="border-bottom: 1px solid #000; padding: 3px;"
                                     t-out="doc.company_name"/>
                                <div><strong>Adresa <small>4</small></strong></div>
                                <div style="border-bottom: 1px solid #000; padding: 3px;"
                                     t-out="doc.company_address"/>
                                <div><strong>Poštanski broj/Mjesto <small>5</small></strong></div>
                                <div style="border-bottom: 1px solid #000; padding: 3px;"
                                     t-out="doc.company_zip_city"/>
                            </td>
                            <td style="width: 40%; vertical-align: top; padding-left: 20px;">
                                <div><strong>Identifikacioni broj <small>1</small></strong></div>
                                <div style="border: 1px solid #000; padding: 5px; font-size: 14px; letter-spacing: 3px;"
                                     t-out="doc.company_vat"/>
                                <div style="margin-top: 10px;"><strong>Period <small>2</small></strong></div>
                                <div style="border-bottom: 1px solid #000; padding: 3px;">
                                    <span t-field="doc.date_from"/> — <span t-field="doc.date_to"/>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- I. Isporuke i nabavke -->
                    <div style="font-weight: bold; margin: 10px 0;">
                        I. Isporuke i nabavke (svi iznosi iskazani bez PDV-a)
                    </div>
                    <table class="table table-sm table-bordered" style="font-size: 10px;">
                        <thead>
                            <tr>
                                <th colspan="3" class="text-center">IZLAZI</th>
                                <th colspan="3" class="text-center">ULAZI</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Isporuke (uključujući i one u vanposlovne svrhe) osim onih u poljima 12 i 13:</td>
                                <td class="text-center" style="width: 5%;"><strong>11</strong></td>
                                <td class="text-end" style="width: 15%;" t-out="'%.2f' % doc.field_11"/>
                                <td>SVE nabavke osim onih u poljima 22 i 23:</td>
                                <td class="text-center" style="width: 5%;"><strong>21</strong></td>
                                <td class="text-end" style="width: 15%;" t-out="'%.2f' % doc.field_21"/>
                            </tr>
                            <tr>
                                <td>Vrijednost izvoza:</td>
                                <td class="text-center"><strong>12</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_12"/>
                                <td>Vrijednost uvoza:</td>
                                <td class="text-center"><strong>22</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_22"/>
                            </tr>
                            <tr>
                                <td>Isporuke oslobođene plaćanja PDV-a:</td>
                                <td class="text-center"><strong>13</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_13"/>
                                <td>Vrijednost nabavke od poljoprivrednika:</td>
                                <td class="text-center"><strong>23</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_23"/>
                            </tr>
                        </tbody>
                    </table>

                    <!-- II. PDV -->
                    <div style="font-weight: bold; margin: 10px 0;">II. Izlazni PDV / Ulazni PDV</div>
                    <table class="table table-sm table-bordered" style="font-size: 10px;">
                        <tbody>
                            <tr>
                                <td rowspan="3" style="vertical-align: middle;">
                                    <strong>PDV obračunat na izlaze</strong><br/>(dobra i usluge)
                                </td>
                                <td rowspan="3" class="text-center" style="width: 5%;"><strong>51</strong></td>
                                <td rowspan="3" class="text-end" style="width: 15%;" t-out="'%.2f' % doc.field_51"/>
                                <td><strong>PDV obračunat na ulaze</strong> (dobra i usluge)<br/>
                                    Od registrovanih obveznika PDV-a osim iznosa u poljima 42 i 43:</td>
                                <td class="text-center" style="width: 5%;"><strong>41</strong></td>
                                <td class="text-end" style="width: 15%;" t-out="'%.2f' % doc.field_41"/>
                            </tr>
                            <tr>
                                <td>PDV na uvoz:</td>
                                <td class="text-center"><strong>42</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_42"/>
                            </tr>
                            <tr>
                                <td>Paušalna naknada za poljoprivrednike:</td>
                                <td class="text-center"><strong>43</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_43"/>
                            </tr>
                            <tr>
                                <td colspan="3"/>
                                <td><strong>Ulazni PDV (ukupno)</strong></td>
                                <td class="text-center"><strong>61</strong></td>
                                <td class="text-end" t-out="'%.2f' % doc.field_61"/>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Result -->
                    <table class="table table-sm table-bordered" style="font-size: 10px;">
                        <tr>
                            <td><strong>Iznos PDV-a za uplatu/povrat</strong><br/>
                                <small>Razlika polja 51 i 61</small></td>
                            <td class="text-center" style="width: 5%;"><strong>71</strong></td>
                            <td class="text-end" style="width: 15%;" t-out="'%.2f' % doc.field_71"/>
                            <td>Zahtjev za povrat</td>
                            <td class="text-center" style="width: 5%;"><strong>80</strong></td>
                            <td style="width: 5%; text-align: center;">
                                <t t-if="doc.field_80">X</t>
                            </td>
                        </tr>
                    </table>

                    <!-- III. Krajnja potrošnja -->
                    <div style="font-weight: bold; margin: 10px 0;">
                        III. PODACI O KRAJNJOJ POTROŠNJI
                    </div>
                    <div style="font-size: 10px; margin-bottom: 5px;">
                        PDV na isporuke licima koja nisu registrovani PDV obveznici u:
                    </div>
                    <table class="table table-sm table-bordered" style="font-size: 10px; width: 50%;">
                        <tr>
                            <td>Federaciji BiH</td>
                            <td class="text-center" style="width: 10%;"><strong>32</strong></td>
                            <td class="text-end" style="width: 25%;" t-out="'%.2f' % doc.field_32"/>
                        </tr>
                        <tr>
                            <td>Republici Srpskoj</td>
                            <td class="text-center"><strong>33</strong></td>
                            <td class="text-end" t-out="'%.2f' % doc.field_33"/>
                        </tr>
                        <tr>
                            <td>Brčko Distriktu</td>
                            <td class="text-center"><strong>34</strong></td>
                            <td class="text-end" t-out="'%.2f' % doc.field_34"/>
                        </tr>
                    </table>

                    <!-- Footer -->
                    <div style="margin-top: 30px; font-size: 10px;">
                        <strong>Ovim potvrđujem da su navedeni podaci tačni.</strong>
                    </div>
                    <table style="width: 100%; margin-top: 20px; font-size: 10px;">
                        <tr>
                            <td style="width: 30%;">Mjesto: ___________________</td>
                            <td style="width: 40%;">Ime i prezime odgovornog lica: ___________________</td>
                        </tr>
                        <tr>
                            <td style="padding-top: 15px;">Datum: ___________________</td>
                            <td style="padding-top: 15px;">Potpis: ___________________</td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
