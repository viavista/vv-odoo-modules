<odoo>

    <record id="account_kuf_report_view_form" model="ir.ui.view">
        <field name="name">account.kuf.report.form</field>
        <field name="model">account.kuf.report</field>
        <field name="arch" type="xml">
            <form string="KUF - Purchase Invoice Book">
                <header>
                    <button
                        name="action_generate"
                        string="Generate"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        name="action_print_pdf"
                        string="Print PDF"
                        type="object"
                        invisible="not line_ids"
                    />
                </header>
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <notebook invisible="not line_ids">
                    <page string="KUF Lines">
                        <field name="line_ids" readonly="1">
                            <list>
                                <field name="sequence" string="No."/>
                                <field name="invoice_number" string="Invoice No."/>
                                <field name="invoice_date" string="Date"/>
                                <field name="partner_name" string="Supplier"/>
                                <field name="partner_vat_id" string="VAT ID"/>
                                <field name="base_amount" string="Excl. VAT" sum="Total"/>
                                <field name="total_with_pdv" string="Incl. VAT" sum="Total"/>
                                <field name="total_input_pdv" string="Input VAT" sum="Total"/>
                                <field name="deductible_pdv" string="Deductible" sum="Total"/>
                                <field name="non_deductible_pdv" string="Non-deduct." sum="Total" optional="show"/>
                                <field name="non_pdv_purchase" string="Non-VAT" sum="Total" optional="hide"/>
                                <field name="flat_rate_amount" string="Flat-rate" sum="Total" optional="hide"/>
                                <field name="farmer_rate" string="5% farmer" sum="Total" optional="hide"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_account_kuf_report" model="ir.actions.act_window">
        <field name="name">KUF - Purchase Invoice Book</field>
        <field name="res_model">account.kuf.report</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
