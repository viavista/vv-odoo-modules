<odoo>

    <record id="account_kif_report_view_form" model="ir.ui.view">
        <field name="name">account.kif.report.form</field>
        <field name="model">account.kif.report</field>
        <field name="arch" type="xml">
            <form string="KIF - Sales Invoice Book">
                <header>
                    <button
                        name="action_generate"
                        string="Generate"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        name="action_print_pdf"
                        string="Print PDF"
                        type="object"
                        invisible="not line_ids"
                    />
                </header>
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <notebook invisible="not line_ids">
                    <page string="KIF Lines">
                        <field name="line_ids" readonly="1">
                            <list>
                                <field name="sequence" string="No."/>
                                <field name="invoice_number" string="Invoice No."/>
                                <field name="invoice_date" string="Date"/>
                                <field name="partner_name" string="Customer"/>
                                <field name="partner_vat_id" string="VAT ID"/>
                                <field name="base_amount" string="Base" sum="Total"/>
                                <field name="export_amount" string="Export" sum="Total"/>
                                <field name="exempt_amount" string="Exempt" sum="Total"/>
                                <field name="pdv_amount" string="VAT" sum="Total"/>
                                <field name="registered_base" string="Reg. base" sum="Total" optional="show"/>
                                <field name="registered_pdv" string="Reg. VAT" sum="Total" optional="show"/>
                                <field name="fc_fbih" string="FBiH" sum="Total" optional="hide"/>
                                <field name="fc_rs" string="RS" sum="Total" optional="hide"/>
                                <field name="fc_brcko" string="Brcko" sum="Total" optional="hide"/>
                                <field name="fc_pdv" string="FC VAT" sum="Total" optional="hide"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_account_kif_report" model="ir.actions.act_window">
        <field name="name">KIF - Sales Invoice Book</field>
        <field name="res_model">account.kif.report</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
