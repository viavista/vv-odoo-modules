<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.mail.telegram</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Telegram" string="Telegram" data-key="mail_telegram">
                    <block title="Bot Configuration">
                        <setting
                            string="Bot Token"
                            help="Create a bot via @BotFather on Telegram to get the token.">
                            <field name="mail_telegram_bot_token" password="True"/>
                        </setting>
                        <setting
                            string="Default Chat ID"
                            help="Default chat or group ID for notifications.">
                            <field name="mail_telegram_default_chat_id"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
