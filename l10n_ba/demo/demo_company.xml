<odoo>

    <record id="base.partner_demo_company_ba" model="res.partner" forcecreate="1">
        <field name="name">BA Company</field>
        <field name="vat">BA4200000000000</field>
        <field name="street">Maršala Tita 10</field>
        <field name="city">Sarajevo</field>
        <field name="zip">71000</field>
        <field name="country_id" ref="base.ba"/>
        <field name="phone">+387 33 123 456</field>
        <field name="email">info@company.baexample.com</field>
        <field name="is_company" eval="True"/>
    </record>

    <record id="base.demo_company_ba" model="res.company" forcecreate="1">
        <field name="name">BA Company</field>
        <field name="partner_id" ref="base.partner_demo_company_ba"/>
        <field name="l10n_ba_court_name">Općinski sud u Sarajevu</field>
        <field name="l10n_ba_court_registration">65-01-0000-25</field>
    </record>

    <record id="base.demo_bank_ba" model="res.partner.bank" forcecreate="1">
        <field name="acc_number">BA391610000000000000</field>
        <field name="partner_id" ref="base.partner_demo_company_ba"/>
        <field name="company_id" ref="base.demo_company_ba"/>
        <field name="allow_out_payment" eval="True"/>
    </record>

    <record id="base.partner_demo_customer_ba" model="res.partner" forcecreate="1">
        <field name="name">BA Kupac</field>
        <field name="vat">BA4200000000001</field>
        <field name="street">Zmaja od Bosne 8</field>
        <field name="city">Sarajevo</field>
        <field name="zip">71000</field>
        <field name="country_id" ref="base.ba"/>
        <field name="phone">+387 33 654 321</field>
        <field name="email">info@customer.baexample.com</field>
        <field name="is_company" eval="True"/>
    </record>

    <function model="res.company" name="_onchange_country_id">
        <value eval="[ref('base.demo_company_ba')]"/>
    </function>

    <function model="res.users" name="write">
        <value eval="[ref('base.user_root'), ref('base.user_admin'), ref('base.user_demo')]"/>
        <value eval="{'company_ids': [(4, ref('base.demo_company_ba'))]}"/>
    </function>

    <function model="account.chart.template" name="try_loading">
        <value eval="[]"/>
        <value>ba</value>
        <value model="res.company" eval="obj().env.ref('base.demo_company_ba')"/>
        <value name="install_demo" eval="True"/>
    </function>

</odoo>
