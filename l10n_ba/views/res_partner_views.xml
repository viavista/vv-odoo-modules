<odoo>
    <record id="view_partner_form_jib" model="ir.ui.view">
        <field name="name">res.partner.form.l10n_ba.jib</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <field name="vat" position="after">
                <field
                    name="l10n_ba_jib"
                    invisible="country_code != 'BA'"
                    placeholder="JIB"
                />
            </field>
        </field>
    </record>
</odoo>
