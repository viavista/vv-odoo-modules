<odoo>

    <record id="view_company_form_l10n_ba" model="ir.ui.view">
        <field name="name">res.company.form.inherit.l10n_ba</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <field name="company_registry" position="after">
                <field name="l10n_ba_court_name"
                       invisible="country_code != 'BA'"/>
                <field name="l10n_ba_court_registration"
                       invisible="country_code != 'BA'"/>
                <field name="l10n_ba_activity_code"
                       invisible="country_code != 'BA'"/>
            </field>
        </field>
    </record>

</odoo>
