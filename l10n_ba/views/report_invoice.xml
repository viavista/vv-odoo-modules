<odoo>

    <template id="report_invoice_document_l10n_ba"
              inherit_id="account.report_invoice_document">

        <!-- Add "Place of Issue" column at the start of the informations row
             for BA companies. Source: company.city. -->
        <xpath expr="//div[@name='invoice_date']" position="before">
            <div class="col"
                 t-if="o.company_id.country_code == 'BA' and o.company_id.city"
                 name="l10n_ba_place_of_issue">
                <strong>Place of Issue</strong>
                <div t-field="o.company_id.city">Sarajevo</div>
            </div>
        </xpath>

        <!-- Non-VAT taxpayer note for BA companies that have no VAT number set
             AND no fiscal position chosen. When a fiscal position is set, the
             stock template shows its note via o.fiscal_position_id.note. -->
        <xpath expr="//div[@name='qr_code_placeholder']" position="before">
            <p class="mb-2"
               t-if="o.company_id.country_code == 'BA'
                     and not o.company_id.vat
                     and not o.fiscal_position_id
                     and o.move_type in ('out_invoice', 'out_refund', 'out_receipt')"
               name="l10n_ba_non_vat_note">
                <em>VAT not charged — taxpayer not in the VAT system (Article 44 of the BiH VAT Law).</em>
            </p>
        </xpath>

        <!-- Bank accounts block for BA companies, inserted before the QR code area:
             - If a specific partner_bank_id is selected on the invoice but no
               payment_reference exists, show that single account (the stock
               template's payment_communication div hides itself otherwise).
             - If no partner_bank_id is selected, list all active company bank
               accounts so the customer can choose — standard FBiH practice. -->
        <xpath expr="//div[@name='qr_code_placeholder']" position="before">
            <div class="mb-3"
                 t-if="o.company_id.country_code == 'BA' and o.move_type in ('out_invoice', 'in_refund')"
                 name="l10n_ba_bank_accounts">
                <t t-if="o.partner_bank_id and not o.payment_reference">
                    <p>
                        <strong>Bank Account:</strong>
                        <span t-field="o.partner_bank_id"/>
                    </p>
                </t>
                <t t-elif="not o.partner_bank_id and o.company_id.bank_ids">
                    <p class="mb-1"><strong>Bank Accounts</strong></p>
                    <table class="table table-sm table-borderless mb-0">
                        <tr t-foreach="o.company_id.bank_ids" t-as="bank">
                            <td t-out="bank.bank_id.name or ''"/>
                            <td class="text-end" t-field="bank.acc_number"/>
                        </tr>
                    </table>
                </t>
            </div>
        </xpath>

    </template>

</odoo>
