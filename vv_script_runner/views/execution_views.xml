<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="script_execution_view_list" model="ir.ui.view">
        <field name="name">script.execution.list</field>
        <field name="model">script.execution</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="script_name"/>
                <field name="script_id" optional="hide"/>
                <field name="user_id"/>
                <field name="dry_run" optional="show"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'running'"
                    decoration-success="state == 'success'"
                    decoration-danger="state == 'error'"/>
                <field name="date_start"/>
                <field name="duration" string="Duration (s)"/>
            </list>
        </field>
    </record>

    <record id="script_execution_view_form" model="ir.ui.view">
        <field name="name">script.execution.form</field>
        <field name="model">script.execution</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <widget name="execution_auto_refresh"/>
                <header>
                    <button name="action_mark_failed" type="object"
                        string="Mark as Failed" class="btn-secondary"
                        invisible="state != 'running'"
                        confirm="Mark this execution as failed? Only use this if the execution is stuck (e.g. after a server restart)."/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="script_name"/>
                            <field name="script_id"/>
                            <field name="user_id"/>
                            <field name="dry_run"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Log Output" name="log">
                            <field name="log_output" nolabel="1"/>
                        </page>
                        <page string="Error" name="error" invisible="state != 'error'">
                            <field name="error_output" nolabel="1"/>
                        </page>
                        <page string="Parameters" name="params">
                            <group>
                                <field name="text_params"/>
                                <field name="file_params_display"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_script_execution" model="ir.actions.act_window">
        <field name="name">Script Executions</field>
        <field name="res_model">script.execution</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
