<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="script_run_wizard_view_form" model="ir.ui.view">
        <field name="name">script.run.wizard.form</field>
        <field name="model">script.run.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Script">
                <group>
                    <field name="script_id" readonly="1" force_save="1"/>
                    <field name="description" placeholder="Optional: why are you running this script?"/>
                </group>
                <footer>
                    <button string="Run" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
